{
  "layout": "SlideLayout",
  "zones": {
    "CollapsiblePanel": {
      "component": "CollapsiblePanel",
      "props": {
        "collapsed": true,
        "children": [
          { "component": "AudioInputDeviceSelector", "props": {} },
          { "component": "DividerLine", "props": {} },
          { "component": "AudioFrequencyGenerator", "props": {} },
          { "component": "DividerLine", "props": {} },
          { "component": "AudioRecordButton", "props": { "busId": "main" } },
          { "component": "AudioFileUploader", "props": { "busId": "main" } },
          { "component": "AudioRecordingDebug", "props": { "busId": "main" } },
          { "component": "DividerLine", "props": {} },
          { "component": "AudioRecordButton", "props": { "busId": "second" } },
          { "component": "AudioFileUploader", "props": { "busId": "second" } },
          { "component": "AudioRecordingDebug", "props": { "busId": "second" } }
        ]
      }
    },

    "topGraph": {
      "component": "AudioRecordingGraph",
      "props": { "busId": "main", "label": "Graph 1", "enableToggle": true, "initialView": "time" },
      "slideable": true,
      "slideLabel": "Top Graph",
      "slideDirection": "top",
      "slideGroup": "topBottom",
      "defaultOpen": true
    },

    "bottomGraph": {
      "component": "AudioRecordingGraph",
      "props": { "busId": "second", "label": "Graph 2", "enableToggle": true, "initialView": "time" },
      "slideable": true,
      "slideLabel": "Bottom Graph",
      "slideDirection": "bottom",
      "slideGroup": "topBottom",
      "defaultOpen": true
    },

    "leftPanel": {
      "component": "AudioControlsPanel",
      "props": { "showSecondControls": true }
    }
  },

  "grid": {
    "xs": {
      "areas": [
        ["CollapsiblePanel"],
        ["topGraph"],
        ["bottomGraph"]
      ],
      "columns": ["1fr"],
      "rows": ["60px", "1fr", "1fr"]
    },

    "xl": {
      "areas": [
        ["leftPanel", "topGraph"],
        ["leftPanel", "bottomGraph"]
      ],
      "columns": ["2fr", "8fr"],
      "rows": ["1fr", "1fr"]
    }
  }
}

